{
  "name": "@appneurox/learningos",
  "version": "1.0.0",
  "description": "LearningOS: Operating layer for courses, lessons, assessments, certifications, learning paths, and training management.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "npm run build && node dist/main.js",
    "seed": "npm run build && node dist/seed-state.js",
    "reset": "rm -f data/learningos.db.json && npm run seed",
    "test": "npm run build && node --test tests/*.test.cjs"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "appneurox",
    "learningos",
    "operating-system",
    "lms",
    "education",
    "training"
  ],
  "appneurox": {
    "os": "learningos",
    "domain": "learning",
    "modes": [
      "standalone",
      "platform"
    ],
    "manifest": "./manifest.json"
  }
}
