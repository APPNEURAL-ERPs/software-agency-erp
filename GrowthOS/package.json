{
  "name": "@appneurox/growthos",
  "version": "1.0.0",
  "description": "GrowthOS: operating layer for campaigns, funnels, experiments, acquisition, activation, retention, and growth loops.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "npm run build && node dist/main.js",
    "seed": "npm run build && node dist/seed-state.js",
    "reset": "rm -f data/growthos.db.json && npm run seed",
    "test": "npm run build && node --test tests/*.test.cjs"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.7.5"
  },
  "keywords": [
    "appneurox",
    "growthos",
    "growth",
    "operating-system",
    "campaigns",
    "funnels",
    "experiments"
  ],
  "appneurox": {
    "os": "growthos",
    "domain": "growth",
    "modes": [
      "standalone",
      "platform"
    ],
    "manifest": "./manifest.json"
  }
}
