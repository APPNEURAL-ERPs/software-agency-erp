{
  "id": "growthos",
  "name": "GrowthOS",
  "package": "@appneurox/growthos",
  "version": "1.0.0",
  "description": "Growth strategy, campaigns, funnels, experiments, lead generation, activation, retention, and revenue growth",
  "modes": [
    "standalone",
    "platform"
  ],
  "status": "active",
  "ownership": {
    "owner": "APPNEURAL",
    "domainOwner": "GrowthOS Team",
    "visibility": "private",
    "reviewDate": "TBD"
  },
  "api": {
    "basePath": "/v1/growth",
    "standalonePath": "/growthos",
    "docsPath": "/docs"
  },
  "entrypoints": {
    "api": "./dist/main.js",
    "manifest": "./manifest.json"
  },
  "commands": [
    "growth.strategy.create",
    "growth.funnel.build",
    "growth.campaign.launch",
    "growth.experiment.run"
  ],
  "workflows": [
    "growth.default.workflow"
  ],
  "events": {
    "publishes": [
      "growth.strategy.created",
      "growth.campaign.launched",
      "growth.experiment.completed",
      "growth.funnel.optimized"
    ],
    "subscribes": []
  },
  "permissions": [
    "growth.strategy.read",
    "growth.strategy.write",
    "growth.funnel.read",
    "growth.funnel.write",
    "growth.campaign.read",
    "growth.campaign.write",
    "growth.experiment.read",
    "growth.experiment.write",
    "growth.audience.read",
    "growth.audience.write",
    "growth.analytics.read"
  ],
  "dependencies": {
    "required": [
      "@appneurox/platformos",
      "@appneurox/analyticsos"
    ],
    "optional": [
      "@appneurox/salesos",
      "@appneurox/contentos",
      "@appneurox/websiteos"
    ]
  },
  "dataClassification": "internal",
  "relatedSystems": [
    "platformos",
    "analyticsos",
    "salesos",
    "contentos",
    "websiteos"
  ],
  "runtime": {}
}
