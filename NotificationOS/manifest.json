{
  "id": "notificationos",
  "name": "NotificationOS",
  "package": "@appneurox/notificationos",
  "version": "1.0.0",
  "description": "Communication delivery engine for emails, WhatsApp, SMS, push, in-app alerts, reminders, announcements, campaigns, and system alerts",
  "modes": [
    "standalone",
    "platform"
  ],
  "status": "active",
  "ownership": {
    "owner": "APPNEURAL",
    "domainOwner": "NotificationOS Team",
    "visibility": "private",
    "reviewDate": "TBD"
  },
  "api": {
    "basePath": "/v1/notifications",
    "standalonePath": "/notificationos",
    "docsPath": "/docs"
  },
  "entrypoints": {
    "api": "./dist/main.js",
    "manifest": "./manifest.json"
  },
  "commands": [
    "notification.send",
    "notification.template.create",
    "notification.schedule.create",
    "notification.rule.create",
    "notification.preference.update"
  ],
  "workflows": [
    "notification.default.workflow"
  ],
  "events": {
    "publishes": [
      "notification.sent",
      "notification.delivered",
      "notification.failed",
      "notification.template.created",
      "notification.rule.triggered"
    ],
    "subscribes": [
      "billing.payment.completed",
      "learning.class.scheduled",
      "support.ticket.updated",
      "security.alert.triggered"
    ]
  },
  "permissions": [
    "notification.read",
    "notification.write",
    "notification.send",
    "notification.template.manage",
    "notification.rule.manage",
    "notification.preference.manage",
    "notification.analytics.read"
  ],
  "dependencies": {
    "required": [
      "@appneurox/platformos",
      "@appneurox/securityos"
    ],
    "optional": [
      "@appneurox/billingos",
      "@appneurox/learningos",
      "@appneurox/supportos"
    ]
  },
  "dataClassification": "internal",
  "channels": [
    "email",
    "whatsapp",
    "sms",
    "push",
    "in_app",
    "slack",
    "teams",
    "webhook",
    "voice"
  ],
  "relatedSystems": [
    "platformos",
    "securityos",
    "billingos",
    "learningos",
    "supportos",
    "identityos",
    "analyticsos"
  ],
  "runtime": {
    "port": 5900,
    "localBaseUrl": "http://localhost:5900"
  }
}
