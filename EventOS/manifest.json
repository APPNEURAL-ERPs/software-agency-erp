{
  "id": "eventos",
  "name": "EventOS",
  "package": "@appneurox/eventos",
  "version": "1.0.0",
  "description": "Domain events, event bus, event schema registry, subscriptions, webhooks, replay, and async communication",
  "modes": [
    "standalone",
    "platform"
  ],
  "status": "active",
  "ownership": {
    "owner": "APPNEURAL",
    "domainOwner": "EventOS Team",
    "visibility": "private",
    "reviewDate": "TBD"
  },
  "api": {
    "basePath": "/v1/events",
    "standalonePath": "/eventos",
    "docsPath": "/docs"
  },
  "entrypoints": {
    "api": "./dist/main.js",
    "manifest": "./manifest.json"
  },
  "commands": [
    "event.publish",
    "event.subscribe",
    "event.replay"
  ],
  "workflows": [
    "event.default.workflow"
  ],
  "agents": [],
  "events": {
    "publishes": [
      "event.published",
      "event.failed",
      "event.dead_lettered"
    ],
    "subscribes": []
  },
  "permissions": [
    "event.read",
    "event.write",
    "event.publish",
    "event.subscribe",
    "event.replay",
    "event.schema.read",
    "event.schema.write",
    "event.audit.read"
  ],
  "dependencies": {
    "required": [
      "@appneurox/platformos",
      "@appneurox/securityos"
    ],
    "optional": [
      "@appneurox/aios",
      "@appneurox/auditos"
    ]
  },
  "dataClassification": "internal",
  "relatedSystems": [
    "platformos",
    "securityos",
    "aios",
    "auditos"
  ],
  "runtime": {
    "port": 5800,
    "localBaseUrl": "http://localhost:5800"
  }
}
