{
  "id": "securityos",
  "name": "SecurityOS",
  "package": "@appneurox/securityos",
  "version": "1.0.0",
  "description": "Auth, roles, permissions, policies, approvals, secrets, and audit",
  "modes": [
    "standalone",
    "platform"
  ],
  "status": "active",
  "ownership": {
    "owner": "APPNEURAL",
    "domainOwner": "SecurityOS Team",
    "visibility": "private",
    "reviewDate": "TBD"
  },
  "api": {
    "basePath": "/v1/security",
    "standalonePath": "/securityos",
    "docsPath": "/docs"
  },
  "entrypoints": {
    "api": "./dist/main.js",
    "manifest": "./manifest.json"
  },
  "commands": [
    "security.item.create",
    "security.workflow.start",
    "security.policy.apply"
  ],
  "workflows": [
    "security.default.workflow"
  ],
  "agents": [
    "security.assistant"
  ],
  "events": {
    "publishes": [
      "security.item.created",
      "security.item.updated",
      "security.workflow.started"
    ],
    "subscribes": []
  },
  "permissions": [
    "security.item.read",
    "security.item.write",
    "security.workflow.run",
    "security.policy.manage",
    "security.audit.read"
  ],
  "dependencies": {
    "required": [
      "@appneurox/platformos"
    ],
    "optional": [
      "@appneurox/complianceos"
    ]
  },
  "dataClassification": "internal",
  "aiAgentSafetyLevel": "approval-required-for-write-actions",
  "relatedSystems": [
    "platformos",
    "complianceos"
  ],
  "runtime": {
    "port": 5400,
    "localBaseUrl": "http://localhost:5400"
  }
}
