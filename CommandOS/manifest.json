{
  "id": "commandos",
  "name": "CommandOS",
  "package": "@appneurox/commandos",
  "version": "1.0.0",
  "description": "Commands, orchestration, intent-to-action, runbooks, automation, and incidents",
  "modes": [
    "standalone",
    "platform"
  ],
  "status": "active",
  "ownership": {
    "owner": "APPNEURAL",
    "domainOwner": "CommandOS Team",
    "visibility": "private",
    "reviewDate": "TBD"
  },
  "api": {
    "basePath": "/v1/command",
    "standalonePath": "/commandos",
    "docsPath": "/docs"
  },
  "entrypoints": {
    "api": "./dist/main.js",
    "manifest": "./manifest.json"
  },
  "commands": [
    "command.item.create",
    "command.workflow.start",
    "command.policy.apply"
  ],
  "workflows": [
    "command.default.workflow"
  ],
  "agents": [
    "command.assistant"
  ],
  "events": {
    "publishes": [
      "command.item.created",
      "command.item.updated",
      "command.workflow.started"
    ],
    "subscribes": []
  },
  "permissions": [
    "command.item.read",
    "command.item.write",
    "command.workflow.run",
    "command.policy.manage",
    "command.audit.read"
  ],
  "dependencies": {
    "required": [
      "@appneurox/platformos",
      "@appneurox/securityos"
    ],
    "optional": [
      "@appneurox/automationos"
    ]
  },
  "dataClassification": "internal",
  "aiAgentSafetyLevel": "approval-required-for-write-actions",
  "relatedSystems": [
    "platformos",
    "automationos",
    "securityos"
  ],
  "runtime": {
    "port": 6700,
    "localBaseUrl": "http://localhost:6700"
  }
}
