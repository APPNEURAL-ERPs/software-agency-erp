{
  "id": "marketplaceos",
  "name": "MarketplaceOS",
  "package": "@appneurox/marketplaceos",
  "version": "1.0.0",
  "description": "Marketplace, listings, sellers, buyers, checkout, licensing, reviews, payouts, and multi-vendor commerce",
  "modes": [
    "standalone",
    "platform"
  ],
  "status": "active",
  "ownership": {
    "owner": "APPNEURAL",
    "domainOwner": "MarketplaceOS Team",
    "visibility": "private",
    "reviewDate": "TBD"
  },
  "api": {
    "basePath": "/v1/marketplace",
    "standalonePath": "/marketplaceos",
    "docsPath": "/docs"
  },
  "entrypoints": {
    "api": "./dist/main.js",
    "manifest": "./manifest.json"
  },
  "commands": [
    "marketplace.listing.create",
    "marketplace.order.process",
    "marketplace.payout.execute"
  ],
  "workflows": [
    "marketplace.default.workflow"
  ],
  "agents": [
    "marketplace.assistant"
  ],
  "events": {
    "publishes": [
      "marketplace.listing.created",
      "marketplace.listing.published",
      "marketplace.order.created",
      "marketplace.payout.processed"
    ],
    "subscribes": []
  },
  "permissions": [
    "marketplace.listing.read",
    "marketplace.listing.write",
    "marketplace.order.read",
    "marketplace.order.write",
    "marketplace.seller.read",
    "marketplace.seller.write",
    "marketplace.buyer.read",
    "marketplace.buyer.write",
    "marketplace.payout.read",
    "marketplace.review.read",
    "marketplace.review.write",
    "marketplace.audit.read"
  ],
  "dependencies": {
    "required": [
      "@appneurox/platformos",
      "@appneurox/billingos",
      "@appneurox/securityos"
    ],
    "optional": []
  },
  "dataClassification": "internal",
  "aiAgentSafetyLevel": "approval-required-for-write-actions",
  "relatedSystems": [
    "platformos",
    "billingos",
    "securityos",
    "toolos",
    "workflowos"
  ],
  "runtime": {
    "port": 10600,
    "localBaseUrl": "http://localhost:10600"
  }
}
