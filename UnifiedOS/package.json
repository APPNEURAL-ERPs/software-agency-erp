{
  "name": "@appneurox/unifiedos",
  "version": "1.0.0",
  "description": "UnifiedOS: Cross-OS orchestration that connects all AppNeuroX OS modules into one registry, dependency graph, workflow layer, event layer, and command center.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "npm run build && node dist/main.js",
    "seed": "npm run build && node dist/scripts/seed.js",
    "reset": "rm -f data/unifiedos.db.json && npm run seed",
    "test": "npm run build"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "appneurox",
    "unifiedos",
    "operating-system",
    "sdk"
  ],
  "appneurox": {
    "os": "unifiedos",
    "domain": "unified",
    "modes": [
      "standalone",
      "platform"
    ],
    "manifest": "./manifest.json"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
