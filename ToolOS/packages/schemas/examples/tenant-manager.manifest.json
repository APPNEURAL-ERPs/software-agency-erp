{
  "id": "tool.tenant.manager",
  "name": "Tenant Manager",
  "packageName": "@appneurox/tenant-manager-tool",
  "version": "1.0.0",
  "description": "Manages tenant lifecycle operations for APPNEUROX platform environments.",
  "category": "platform",
  "type": "manager",
  "ai": {
    "enabled": true,
    "required": false,
    "level": 1,
    "provider": "AIOS"
  },
  "modes": ["platform", "agent-tool"],
  "commands": [
    {
      "name": "tool.tenant.manager.create",
      "description": "Create a tenant.",
      "input": "tenantRequest",
      "output": "tenant"
    },
    {
      "name": "tool.tenant.manager.disable",
      "description": "Disable a tenant.",
      "input": "tenantAction",
      "output": "tenant"
    }
  ],
  "permissions": [
    {
      "name": "tools.tenant.manager.create",
      "required": true
    },
    {
      "name": "tools.tenant.manager.disable",
      "required": true
    }
  ],
  "events": {
    "publishes": ["tool.tenant.manager.created", "tool.tenant.manager.disabled"],
    "subscribes": ["billing.account.created"]
  },
  "api": {
    "basePath": "/v1/tools/tool.tenant.manager"
  },
  "sdk": {
    "namespace": "tools.tenant.manager"
  },
  "cli": {
    "namespace": "tenant manager"
  },
  "inputs": [
    {
      "name": "tenantId",
      "type": "string",
      "required": true
    },
    {
      "name": "plan",
      "type": "string",
      "required": false
    }
  ],
  "outputs": [
    {
      "name": "tenantId",
      "type": "string"
    },
    {
      "name": "status",
      "type": "string"
    }
  ],
  "dependencies": {
    "required": ["@appneurox/toolos"],
    "optional": ["@appneurox/platformos", "@appneurox/aios"],
    "external": []
  },
  "usedBy": ["PlatformOS", "CommandOS", "AIOS"],
  "safety": {
    "requiresApproval": true,
    "sensitiveData": true,
    "allowedForAgents": true,
    "rateLimit": {
      "enabled": true,
      "maxRequests": 30,
      "windowSeconds": 60
    }
  }
}
