{
  "id": "tool.backup.manager",
  "name": "Backup Manager",
  "packageName": "@appneurox/backup-manager-tool",
  "version": "1.0.0",
  "description": "Creates, verifies, and restores operational backups for APPNEUROX platform resources.",
  "category": "operations",
  "type": "manager",
  "ai": {
    "enabled": false,
    "required": false,
    "level": 0
  },
  "modes": ["platform"],
  "commands": [
    {
      "name": "tool.backup.manager.create",
      "description": "Create a backup snapshot.",
      "input": "backupRequest",
      "output": "backupResult"
    },
    {
      "name": "tool.backup.manager.restore",
      "description": "Restore a backup snapshot.",
      "input": "restoreRequest",
      "output": "restoreResult"
    }
  ],
  "permissions": [
    {
      "name": "tools.backup.manager.create",
      "description": "Create backup snapshots.",
      "required": true
    },
    {
      "name": "tools.backup.manager.restore",
      "description": "Restore backup snapshots.",
      "required": true
    }
  ],
  "events": {
    "publishes": ["tool.backup.manager.created", "tool.backup.manager.restored"],
    "subscribes": ["platform.maintenance.started"]
  },
  "api": {
    "basePath": "/v1/tools/tool.backup.manager"
  },
  "sdk": {
    "namespace": "tools.backup.manager"
  },
  "cli": {
    "namespace": "backup manager"
  },
  "inputs": [
    {
      "name": "resourceId",
      "type": "string",
      "required": true
    },
    {
      "name": "mode",
      "type": "string",
      "required": true
    }
  ],
  "outputs": [
    {
      "name": "operationId",
      "type": "string"
    },
    {
      "name": "status",
      "type": "string"
    }
  ],
  "dependencies": {
    "required": ["@appneurox/toolos"],
    "optional": ["@appneurox/securityos", "@appneurox/analyticsos"],
    "external": ["object-storage"]
  },
  "usedBy": ["CommandOS", "OperationsOS", "InfrastructureOS"],
  "safety": {
    "requiresApproval": true,
    "sensitiveData": true,
    "allowedForAgents": false,
    "rateLimit": {
      "enabled": true,
      "maxRequests": 20,
      "windowSeconds": 60
    }
  }
}
