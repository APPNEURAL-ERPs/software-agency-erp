{
  "id": "toolos",
  "name": "ToolOS",
  "package": "@appneurox/toolos",
  "version": "1.0.0",
  "description": "Reusable tool registry and execution gateway for APPNEUROX.",
  "namespace": "tools",
  "modes": [
    "standalone",
    "platform"
  ],
  "status": "active",
  "api": {
    "basePath": "/v1/tools",
    "standalonePath": "/v1/tools",
    "docsPath": "/docs"
  },
  "dependencies": {
    "required": [
      "@appneurox/platformos",
      "@appneurox/securityos"
    ],
    "optional": [
      "@appneurox/agenticos",
      "@appneurox/commandos",
      "@appneurox/automationos",
      "@appneurox/analyticsos"
    ]
  },
  "commands": [
    "tool.definition.create",
    "tool.manifest.validate",
    "tool.package.generate",
    "tool.install",
    "tool.discovery.search",
    "tool.execution.run",
    "tool.approval.approve",
    "tool.credential.create"
  ],
  "permissions": [
    "tool.definitions.view",
    "tool.definitions.create",
    "tool.manifests.validate",
    "tool.packages.generate",
    "tool.installations.manage",
    "tool.executions.run",
    "tool.executions.view",
    "tool.approvals.manage",
    "tools.pdf.generate",
    "tools.qr.generate",
    "tools.domain.check",
    "tools.brand.check"
  ],
  "events": {
    "publishes": [
      "tool.definition.created",
      "tool.execution.completed",
      "tool.execution.failed",
      "tool.approval.requested",
      "tool.approval.approved"
    ],
    "subscribes": [
      "agentic.tool.requested",
      "workflow.tool.requested"
    ]
  },
  "relatedSystems": [
    "agenticos",
    "aios",
    "commandos",
    "automationos",
    "analyticsos",
    "platformos",
    "securityos"
  ],
  "runtime": {
    "port": 6700,
    "localBaseUrl": "http://localhost:6700"
  }
}
