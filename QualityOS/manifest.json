{
  "id": "qualityos",
  "name": "QualityOS",
  "package": "@appneurox/qualityos",
  "version": "1.0.0",
  "description": "QualityOS: QA processes, test cases, bug tracking, feedback, satisfaction, and quality metrics",
  "modes": [
    "standalone",
    "platform"
  ],
  "status": "active",
  "ownership": {
    "owner": "APPNEURAL",
    "domainOwner": "QualityOS Team",
    "visibility": "private",
    "reviewDate": "TBD"
  },
  "api": {
    "basePath": "/v1/quality",
    "standalonePath": "/qualityos",
    "docsPath": "/docs"
  },
  "entrypoints": {
    "api": "./dist/main.js",
    "manifest": "./manifest.json"
  },
  "commands": [
    "quality.checklist.create",
    "quality.testcase.create",
    "quality.bug.create",
    "quality.feedback.collect",
    "quality.metric.track"
  ],
  "workflows": [
    "quality.qa.workflow"
  ],
  "events": {
    "publishes": [
      "quality.test.created",
      "quality.bug.created",
      "quality.release.ready"
    ],
    "subscribes": []
  },
  "permissions": [
    "quality.item.read",
    "quality.item.write",
    "quality.test.run",
    "quality.bug.manage",
    "quality.feedback.manage",
    "quality.metric.read"
  ],
  "dependencies": {
    "required": [
      "@appneurox/platformos"
    ],
    "optional": [
      "@appneurox/aiagos",
      "@appneurox/securityos"
    ]
  },
  "dataClassification": "internal",
  "aiAgentSafetyLevel": "approval-required-for-write-actions",
  "relatedSystems": [
    "platformos",
    "aios",
    "securityos"
  ],
  "runtime": {
    "port": 9900,
    "localBaseUrl": "http://localhost:9900"
  }
}
