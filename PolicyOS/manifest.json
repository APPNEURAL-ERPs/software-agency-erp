{
  "id": "policyos",
  "name": "PolicyOS",
  "package": "@appneurox/policyos",
  "version": "1.0.0",
  "description": "PolicyOS: policies, rules, guardrails, access decisions, rate limits, approval rules, and enforcement",
  "modes": [
    "standalone",
    "platform"
  ],
  "status": "active",
  "ownership": {
    "owner": "APPNEURAL",
    "domainOwner": "PolicyOS Team",
    "visibility": "private",
    "reviewDate": "TBD"
  },
  "api": {
    "basePath": "/v1/policy",
    "standalonePath": "/policyos",
    "docsPath": "/docs"
  },
  "entrypoints": {
    "api": "./dist/main.js",
    "manifest": "./manifest.json"
  },
  "commands": [
    "policy.create",
    "policy.publish",
    "policy.enforce",
    "policy.review"
  ],
  "workflows": [
    "policy.default.workflow"
  ],
  "events": {
    "publishes": [
      "policy.created",
      "policy.updated",
      "policy.published",
      "policy.violated",
      "policy.exception.requested"
    ],
    "subscribes": []
  },
  "permissions": [
    "policy.read",
    "policy.write",
    "policy.publish",
    "policy.enforce",
    "policy.audit.read"
  ],
  "dependencies": {
    "required": [
      "@appneurox/platformos",
      "@appneurox/securityos"
    ],
    "optional": [
      "@appneurox/governanceos",
      "@appneurox/auditos"
    ]
  },
  "dataClassification": "internal",
  "relatedSystems": [
    "securityos",
    "governanceos",
    "auditos",
    "complianceos",
    "platformos"
  ],
  "runtime": {
    "port": 5200,
    "localBaseUrl": "http://localhost:5200"
  }
}
