{
  "name": "@appneurox/mediaos",
  "version": "1.0.0",
  "description": "MediaOS: image, video, audio, creative asset, media library, media processing, streaming, thumbnails, transcoding, and media analytics.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "npm run build && node dist/main.js",
    "seed": "npm run build && node dist/scripts/seed.js",
    "reset": "rm -f data/mediaos.db.json && npm run seed"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "appneurox",
    "mediaos",
    "media",
    "operating-system",
    "sdk"
  ],
  "appneurox": {
    "os": "mediaos",
    "domain": "media",
    "modes": [
      "standalone",
      "platform"
    ],
    "manifest": "./manifest.json"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
