{
  "name": "@appneurox/configos",
  "version": "1.0.0",
  "description": "ConfigOS: Runtime configuration, tenant settings, feature flags, environment config, and OS-level settings management.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "npm run build && node dist/main.js",
    "seed": "npm run build && node dist/scripts/seed.js",
    "reset": "rm -f data/configos.db.json && npm run seed",
    "test": "npm run build && node --test tests/*.test.cjs"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.7.5"
  },
  "keywords": [
    "appneurox",
    "configos",
    "operating-system",
    "configuration",
    "feature-flags",
    "settings"
  ],
  "appneurox": {
    "os": "configos",
    "domain": "config",
    "modes": [
      "standalone",
      "platform"
    ],
    "manifest": "./manifest.json"
  }
}
