{
  "name": "@appneurox/vendoros",
  "version": "1.0.0",
  "description": "VendorOS: vendor management, relationships, performance tracking, contracts, and vendor lifecycle",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "npm run build && node dist/main.js",
    "reset": "rm -f data/vendoros.db.json"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.7.5"
  },
  "keywords": [
    "appneurox",
    "vendoros",
    "operating-system",
    "vendor-management",
    "procurement"
  ],
  "appneurox": {
    "os": "vendoros",
    "domain": "vendor",
    "modes": [
      "standalone",
      "platform"
    ],
    "manifest": "./manifest.json"
  }
}
