{
  "id": "procurementos",
  "name": "ProcurementOS",
  "package": "@appneurox/procurementos",
  "version": "1.0.0",
  "description": "Purchase requests, vendor management, approvals, purchase orders, goods receipts, and procurement lifecycle management",
  "modes": [
    "standalone",
    "platform"
  ],
  "status": "active",
  "ownership": {
    "owner": "APPNEURAL",
    "domainOwner": "ProcurementOS Team",
    "visibility": "private",
    "reviewDate": "TBD"
  },
  "api": {
    "basePath": "/v1/procurement",
    "standalonePath": "/procurementos",
    "docsPath": "/docs"
  },
  "entrypoints": {
    "api": "./dist/main.js",
    "manifest": "./manifest.json"
  },
  "commands": [
    "procurement.request.create",
    "procurement.request.approve",
    "procurement.order.create",
    "procurement.receipt.create"
  ],
  "workflows": [
    "procurement.default.workflow"
  ],
  "events": {
    "publishes": [
      "procurement.request.created",
      "procurement.request.approved",
      "procurement.order.created",
      "procurement.receipt.created",
      "procurement.vendor.selected"
    ],
    "subscribes": [
      "inventory.reorder",
      "vendor.quote.received"
    ]
  },
  "permissions": [
    "procurement.request.read",
    "procurement.request.write",
    "procurement.order.read",
    "procurement.order.write",
    "procurement.vendor.read",
    "procurement.vendor.write",
    "procurement.receipt.read",
    "procurement.receipt.write",
    "procurement.approval.write",
    "procurement.audit.read"
  ],
  "dependencies": {
    "required": [
      "@appneurox/platformos",
      "@appneurox/securityos"
    ],
    "optional": [
      "@appneurox/vendoros",
      "@appneurox/financeos",
      "@appneurox/inventoryos"
    ]
  },
  "dataClassification": "internal",
  "relatedSystems": [
    "platformos",
    "securityos",
    "vendoros",
    "financeos",
    "inventoryos"
  ],
  "runtime": {
    "port": 11100,
    "localBaseUrl": "http://localhost:11100"
  }
}
