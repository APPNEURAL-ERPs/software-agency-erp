{
  "name": "@appneurox/procurementos",
  "version": "1.0.0",
  "description": "ProcurementOS: purchase requests, vendor management, approvals, purchase orders, goods receipts, and procurement lifecycle",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "npm run build && node dist/main.js",
    "reset": "rm -f data/procurementos.db.json && npm run seed",
    "seed": "npm run build && node dist/seed.js"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.7.5"
  },
  "keywords": [
    "appneurox",
    "procurementos",
    "operating-system",
    "procurement",
    "purchasing"
  ],
  "appneurox": {
    "os": "procurementos",
    "domain": "procurement",
    "modes": [
      "standalone",
      "platform"
    ],
    "manifest": "./manifest.json"
  }
}
