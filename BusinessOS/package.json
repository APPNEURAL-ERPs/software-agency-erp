{
  "name": "@appneurox/businessos",
  "version": "1.0.0",
  "description": "BusinessOS: strategy, OKRs, initiatives, operating model, scorecards, and business decisions management.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "npm run build && node dist/main.js",
    "seed": "npm run build && node dist/scripts/seed.js",
    "reset": "rm -f data/businessos.db.json && npm run seed",
    "test": "npm run build && node --test tests/*.test.cjs"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.7.5"
  },
  "keywords": [
    "appneurox",
    "businessos",
    "operating-system",
    "strategy",
    "okr",
    "business"
  ],
  "appneurox": {
    "os": "businessos",
    "domain": "business",
    "modes": [
      "standalone",
      "platform"
    ],
    "manifest": "./manifest.json"
  }
}
