{
  "id": "analyticsos",
  "name": "AnalyticsOS",
  "package": "@appneurox/analyticsos",
  "version": "1.0.0",
  "description": "Analytics dashboards, metrics, funnels, cohorts, attribution, and business intelligence",
  "modes": [
    "standalone",
    "platform"
  ],
  "status": "active",
  "ownership": {
    "owner": "APPNEURAL",
    "domainOwner": "AnalyticsOS Team",
    "visibility": "private",
    "reviewDate": "TBD"
  },
  "api": {
    "basePath": "/v1/analytics",
    "standalonePath": "/analyticsos",
    "docsPath": "/docs"
  },
  "entrypoints": {
    "api": "./dist/main.js",
    "manifest": "./manifest.json"
  },
  "commands": [
    "analytics.dashboard.create",
    "analytics.kpi.create",
    "analytics.report.generate",
    "analytics.event.track",
    "analytics.funnel.analyze",
    "analytics.forecast.run"
  ],
  "workflows": [
    "analytics.default.workflow"
  ],
  "events": {
    "publishes": [
      "analytics.dashboard.created",
      "analytics.kpi.updated",
      "analytics.alert.triggered",
      "analytics.report.generated"
    ],
    "subscribes": []
  },
  "permissions": [
    "analytics.dashboard.read",
    "analytics.dashboard.write",
    "analytics.kpi.read",
    "analytics.kpi.write",
    "analytics.report.read",
    "analytics.report.write",
    "analytics.events.read",
    "analytics.events.write",
    "analytics.funnel.read",
    "analytics.funnel.write",
    "analytics.cohort.read",
    "analytics.cohort.write",
    "analytics.alert.read",
    "analytics.alert.write",
    "analytics.forecast.read",
    "analytics.forecast.write"
  ],
  "dependencies": {
    "required": [
      "@appneurox/platformos",
      "@appneurox/securityos"
    ],
    "optional": []
  },
  "dataClassification": "internal",
  "relatedSystems": [
    "platformos",
    "securityos",
    "aios"
  ],
  "runtime": {
    "port": 7400,
    "localBaseUrl": "http://localhost:7400"
  }
}
