{
  "id": "airesourceos",
  "name": "AIResourceOS",
  "package": "@appneurox/airesourceos",
  "version": "1.0.0",
  "description": "AI resource management, token budgets, model selection, cost tracking, and AI quota management",
  "modes": [
    "standalone",
    "platform"
  ],
  "status": "active",
  "ownership": {
    "owner": "APPNEURAL",
    "domainOwner": "AIResourceOS Team",
    "visibility": "private",
    "reviewDate": "TBD"
  },
  "api": {
    "basePath": "/v1/airesource",
    "standalonePath": "/airesourceos",
    "docsPath": "/docs"
  },
  "entrypoints": {
    "api": "./dist/main.js",
    "manifest": "./manifest.json"
  },
  "commands": [
    "airesource.model.create",
    "airesource.budget.allocate",
    "airesource.usage.track"
  ],
  "workflows": [
    "airesource.default.workflow"
  ],
  "agents": [
    "airesource.assistant"
  ],
  "events": {
    "publishes": [
      "airesource.model.created",
      "airesource.budget.exceeded",
      "airesource.usage.recorded"
    ],
    "subscribes": []
  },
  "permissions": [
    "airesource.model.read",
    "airesource.model.write",
    "airesource.budget.read",
    "airesource.budget.write",
    "airesource.usage.read",
    "airesource.usage.write",
    "airesource.analytics.read"
  ],
  "dependencies": {
    "required": [
      "@appneurox/platformos"
    ],
    "optional": [
      "@appneurox/aios"
    ]
  },
  "dataClassification": "internal",
  "aiAgentSafetyLevel": "approval-required-for-write-actions",
  "relatedSystems": [
    "platformos",
    "aios"
  ],
  "runtime": {
    "port": 12200,
    "localBaseUrl": "http://localhost:12200"
  }
}
