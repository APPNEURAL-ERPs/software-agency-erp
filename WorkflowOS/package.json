{
  "name": "@appneurox/workflowos",
  "version": "1.0.0",
  "description": "WorkflowOS: workflow orchestration, triggers, actions, conditions, approvals, escalations, state management, execution, and monitoring",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "npm run build && node dist/main.js",
    "seed": "npm run build && node dist/scripts/seed.js",
    "reset": "rm -f data/workflowos.db.json && npm run seed",
    "test": "npm run build && node --test tests/*.test.cjs"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.7.5"
  },
  "keywords": [
    "appneurox",
    "workflowos",
    "operating-system",
    "orchestration",
    "workflow",
    "automation"
  ],
  "appneurox": {
    "os": "workflowos",
    "domain": "workflow",
    "modes": [
      "standalone",
      "platform"
    ],
    "manifest": "./manifest.json"
  }
}
