{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noImplicitAny": false
  },
  "include": [
    "src/main.ts",
    "src/service.ts",
    "src/routes.ts",
    "src/docs.ts",
    "src/seed-state.ts",
    "src/domain.ts",
    "src/core/datastore.ts",
    "src/core/domain.ts",
    "src/core/errors.ts",
    "src/core/http.ts",
    "src/core/id.ts",
    "src/core/utils.ts"
  ],
  "exclude": [
    "src/modules/**/*",
    "src/services/**/*",
    "src/types/**/*",
    "src/scripts/**/*",
    "src/core/event-bus.ts",
    "src/core/security.ts"
  ]
}
