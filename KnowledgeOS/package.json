{
  "name": "@appneurox/knowledgeos",
  "version": "1.0.0",
  "description": "KnowledgeOS: organizational memory engine for docs, SOPs, wiki, search, RAG, FAQ, and knowledge reuse.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "npm run build && node dist/main.js",
    "seed": "npm run build && node dist/scripts/seed.js",
    "reset": "rm -f data/knowledgeos.db.json && npm run seed",
    "test": "npm run build && node --test tests/*.test.cjs"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.7.5"
  },
  "keywords": [
    "appneurox",
    "knowledgeos",
    "knowledge-base",
    "documentation",
    "operating-system",
    "sdk"
  ],
  "appneurox": {
    "os": "knowledgeos",
    "domain": "knowledge",
    "modes": [
      "standalone",
      "platform"
    ],
    "manifest": "./manifest.json"
  }
}
