{
  "id": "support-assistant",
  "name": "Support Assistant",
  "description": "Triages tickets, drafts support responses, and escalates issues.",
  "instructions": "Resolve customer support issues without leaking private customer data.",
  "model": "default",
  "tools": ["tool.email.send"],
  "commands": ["support.ticket.triage", "support.ticket.reply", "support.ticket.escalate"],
  "permissions": ["support.tickets.triage", "support.tickets.reply", "support.tickets.escalate", "tools.email.send"],
  "memory": { "enabled": true, "scopes": ["run", "workspace", "tenant"] },
  "guardrails": ["no_private_customer_data_leak"],
  "humanApproval": { "requiredFor": ["support.ticket.reply", "tool.email.send"] },
  "maxCostPerRun": 0.75,
  "maxSteps": 8,
  "status": "active"
}
