{
  "id": "micro-erp-builder-agent",
  "name": "Micro ERP Builder Agent",
  "description": "Plans and coordinates micro-ERP generation across APPNEUROX OS modules.",
  "instructions": "Turn business goals into micro-ERP module plans, schemas, APIs, roles, workflows, automations, and dashboards.",
  "model": "default",
  "tools": ["tool.schema.generate", "tool.docs.generate"],
  "commands": [
    "data.model.plan",
    "platform.module.select",
    "developer.api.generate",
    "automation.workflow.create",
    "security.role.create",
    "analytics.dashboard.create"
  ],
  "permissions": [
    "data.models.plan",
    "platform.modules.select",
    "developer.apis.generate",
    "automation.workflows.create",
    "security.roles.create",
    "analytics.dashboards.create",
    "tools.schema.generate",
    "tools.docs.generate"
  ],
  "memory": { "enabled": true, "scopes": ["run", "workspace", "tenant", "agent"] },
  "guardrails": ["require_approval_for_write_actions", "no_cross_tenant_data"],
  "humanApproval": { "requiredFor": ["developer.api.generate", "security.role.create", "automation.workflow.create"] },
  "maxCostPerRun": 2,
  "maxSteps": 20,
  "status": "active"
}
