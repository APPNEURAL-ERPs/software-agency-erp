{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noImplicitAny": false
  },
  "files": [
    "src/main.ts",
    "src/docs.ts",
    "src/service.ts",
    "src/seed-state.ts",
    "src/core/datastore.ts",
    "src/core/domain.ts",
    "src/core/errors.ts",
    "src/core/http.ts",
    "src/core/id.ts",
    "src/core/utils.ts",
    "src/modules/routes.ts"
  ]
}
