{
  "id": "agenticos",
  "name": "AgenticOS",
  "package": "@appneurox/agenticos",
  "version": "1.0.0",
  "description": "AI agent operating system for building, managing, securing, monitoring, and scaling safe tool-connected agents.",
  "modes": [
    "standalone",
    "platform"
  ],
  "status": "active",
  "ownership": {
    "owner": "APPNEURAL",
    "domainOwner": "AgenticOS Team",
    "visibility": "private",
    "reviewDate": "TBD"
  },
  "api": {
    "basePath": "/v1/agentic",
    "standalonePath": "/agentic",
    "docsPath": "/docs"
  },
  "entrypoints": {
    "api": "./dist/main.js",
    "manifest": "./manifest.json"
  },
  "commands": [
    "agentic.agent.create",
    "agentic.agent.run",
    "agentic.workflow.start",
    "agentic.approval.grant"
  ],
  "workflows": [
    "agentic.default.workflow"
  ],
  "agents": [
    "agentic.builder"
  ],
  "events": {
    "publishes": [
      "agentic.agent.created",
      "agentic.agent.run.started",
      "agentic.agent.run.completed",
      "agentic.approval.requested",
      "agentic.guardrail.triggered"
    ],
    "subscribes": []
  },
  "permissions": [
    "agentic.agent.read",
    "agentic.agent.write",
    "agentic.agent.run",
    "agentic.template.read",
    "agentic.template.write",
    "agentic.tool.read",
    "agentic.tool.write",
    "agentic.workflow.read",
    "agentic.workflow.write",
    "agentic.approval.manage",
    "agentic.guardrail.read",
    "agentic.guardrail.write",
    "agentic.memory.read",
    "agentic.memory.write",
    "agentic.evaluation.read",
    "agentic.evaluation.write",
    "agentic.audit.read"
  ],
  "dependencies": {
    "required": [
      "@appneurox/aios",
      "@appneurox/toolos",
      "@appneurox/securityos"
    ],
    "optional": [
      "@appneurox/automationos",
      "@appneurox/analyticsos"
    ]
  },
  "dataClassification": "internal",
  "aiAgentSafetyLevel": "approval-required-for-write-actions",
  "relatedSystems": [
    "aios",
    "toolos",
    "securityos",
    "automationos",
    "analyticsos"
  ],
  "runtime": {
    "port": 7000,
    "localBaseUrl": "http://localhost:7000"
  }
}
