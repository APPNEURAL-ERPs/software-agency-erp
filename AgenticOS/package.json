{
  "name": "@appneurox/agenticos",
  "version": "1.0.0",
  "description": "AgenticOS: AI agent operating system for building, managing, securing, monitoring, and scaling safe tool-connected agents.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "npm run build && node dist/main.js",
    "reset": "rm -f data/agenticos.db.json && npm run dev",
    "test": "npm run build && node --test tests/*.test.cjs"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "appneurox",
    "agenticos",
    "operating-system",
    "ai-agents",
    "tool-registry",
    "guardrails",
    "workflows"
  ],
  "appneurox": {
    "os": "agenticos",
    "domain": "agentic",
    "modes": [
      "standalone",
      "platform"
    ],
    "manifest": "./manifest.json"
  }
}
