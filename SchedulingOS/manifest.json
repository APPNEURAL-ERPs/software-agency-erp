{
  "id": "schedulingos",
  "name": "SchedulingOS",
  "package": "@appneurox/schedulingos",
  "version": "1.0.0",
  "description": "Scheduling, appointments, availability, calendars, bookings, reminders, and time-based coordination",
  "modes": [
    "standalone",
    "platform"
  ],
  "status": "active",
  "ownership": {
    "owner": "APPNEURAL",
    "domainOwner": "SchedulingOS Team",
    "visibility": "private",
    "reviewDate": "TBD"
  },
  "api": {
    "basePath": "/v1/scheduling",
    "standalonePath": "/schedulingos",
    "docsPath": "/docs"
  },
  "entrypoints": {
    "api": "./dist/main.js",
    "manifest": "./manifest.json"
  },
  "commands": [
    "scheduling.schedule.create",
    "scheduling.booking.create",
    "scheduling.availability.check",
    "scheduling.reminder.schedule"
  ],
  "workflows": [
    "scheduling.default.workflow"
  ],
  "events": {
    "publishes": [
      "scheduling.booking.created",
      "scheduling.booking.confirmed",
      "scheduling.booking.cancelled",
      "scheduling.booking.rescheduled",
      "scheduling.reminder.due",
      "scheduling.slot.conflict"
    ],
    "subscribes": [
      "notification.send",
      "communication.conversation.create"
    ]
  },
  "permissions": [
    "scheduling.read",
    "scheduling.schedule.write",
    "scheduling.booking.write",
    "scheduling.availability.write",
    "scheduling.reminder.write",
    "scheduling.audit.read"
  ],
  "dependencies": {
    "required": [
      "@appneurox/platformos"
    ],
    "optional": [
      "@appneurox/notificationos",
      "@appneurox/communicationos"
    ]
  },
  "dataClassification": "internal",
  "relatedSystems": [
    "platformos",
    "notificationos",
    "communicationos",
    "salesos",
    "supportos",
    "learningos",
    "peopleos",
    "operationsos"
  ],
  "runtime": {
    "port": 11500,
    "localBaseUrl": "http://localhost:11500"
  }
}
