{
  "name": "@appneurox/supportos",
  "version": "1.0.0",
  "description": "SupportOS: customer support, helpdesk, ticketing, SLA, knowledge base, escalation, and support quality management",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "npm run build && node dist/main.js",
    "seed": "npm run build && node dist/scripts/seed.js",
    "reset": "rm -f data/supportos.db.json && npm run seed",
    "test": "npm run build && node --test tests/*.test.cjs"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.7.5"
  },
  "keywords": [
    "appneurox",
    "supportos",
    "operating-system",
    "support",
    "helpdesk",
    "tickets",
    "sla"
  ],
  "appneurox": {
    "os": "supportos",
    "domain": "support",
    "modes": [
      "standalone",
      "platform"
    ],
    "manifest": "./manifest.json"
  }
}
