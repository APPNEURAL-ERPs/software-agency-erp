{
  "name": "@appneurox/brandos",
  "version": "1.0.0",
  "description": "BrandOS: brand identity, brand strategy, visual consistency, messaging, content style, and brand asset management layer",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "npm run build && node dist/main.js",
    "seed": "npm run build && node dist/seed.js",
    "reset": "rm -f data/brandos.db.json && npm run seed",
    "test": "npm run build && node --test tests/*.test.cjs"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "appneurox",
    "brandos",
    "brand",
    "identity",
    "operating-system",
    "sdk"
  ],
  "appneurox": {
    "os": "brandos",
    "domain": "brand",
    "modes": [
      "standalone",
      "platform"
    ],
    "manifest": "./manifest.json"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
