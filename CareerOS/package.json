{
  "name": "@appneurox/careeros",
  "version": "1.0.0",
  "description": "CareerOS: Jobs, hiring pipeline, applications, interviews, offers, onboarding, and career paths",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "npm run build && node dist/main.js",
    "seed": "npm run build && node dist/seed.js",
    "reset": "rm -f data/careeros.db.json && npm run seed"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.7.5"
  },
  "keywords": [
    "appneurox",
    "careeros",
    "operating-system",
    "hiring",
    "career"
  ],
  "appneurox": {
    "os": "careeros",
    "domain": "career",
    "modes": [
      "standalone",
      "platform"
    ],
    "manifest": "./manifest.json"
  }
}
