{
  "id": "communicationos",
  "name": "CommunicationOS",
  "package": "@appneurox/communicationos",
  "version": "1.0.0",
  "description": "Communication, messaging, inbox, email, chat, WhatsApp, calling, meeting, announcements, and collaboration layer of APPNEURAL",
  "modes": [
    "standalone",
    "platform"
  ],
  "status": "active",
  "ownership": {
    "owner": "APPNEURAL",
    "domainOwner": "CommunicationOS Team",
    "visibility": "private",
    "reviewDate": "TBD"
  },
  "api": {
    "basePath": "/v1/communication",
    "standalonePath": "/communicationos",
    "docsPath": "/docs"
  },
  "entrypoints": {
    "api": "./dist/main.js",
    "manifest": "./manifest.json"
  },
  "commands": [
    "communication.message.send",
    "communication.conversation.create",
    "communication.channel.create",
    "communication.call.start",
    "communication.conference.schedule",
    "communication.template.send"
  ],
  "workflows": [
    "communication.default.workflow"
  ],
  "agents": [
    "communication.assistant"
  ],
  "events": {
    "publishes": [
      "communication.message.sent",
      "communication.message.received",
      "communication.conversation.created",
      "communication.conversation.updated",
      "communication.call.started",
      "communication.call.ended"
    ],
    "subscribes": [
      "notification.delivered",
      "user.online",
      "user.offline"
    ]
  },
  "permissions": [
    "communication.message.read",
    "communication.message.write",
    "communication.conversation.read",
    "communication.conversation.write",
    "communication.channel.read",
    "communication.channel.write",
    "communication.call.read",
    "communication.call.write",
    "communication.audit.read"
  ],
  "dependencies": {
    "required": [
      "@appneurox/platformos",
      "@appneurox/securityos"
    ],
    "optional": []
  },
  "dataClassification": "internal",
  "communicationSafetyLevel": "approval-required-for-write-actions",
  "relatedSystems": [
    "platformos",
    "securityos",
    "notificationos",
    "salesos",
    "supportos",
    "clientos",
    "learningos"
  ],
  "runtime": {
    "port": 10900,
    "localBaseUrl": "http://localhost:10900"
  }
}
