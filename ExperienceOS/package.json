{
  "name": "@appneurox/experienceos",
  "version": "1.0.0",
  "description": "ExperienceOS: user experience, customer experience, journeys, onboarding, personalization, A/B testing, and experience optimization.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "npm run build && node dist/main.js",
    "seed": "npm run build && node dist/seed.js",
    "reset": "rm -f data/experienceos.db.json && npm run seed",
    "test": "npm run build && node --test tests/*.test.cjs"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.7.5"
  },
  "keywords": [
    "appneurox",
    "experienceos",
    "operating-system",
    "user-experience",
    "customer-experience",
    "journey",
    "onboarding",
    "personalization",
    "ab-testing"
  ],
  "appneurox": {
    "os": "experienceos",
    "domain": "experience",
    "modes": [
      "standalone",
      "platform"
    ],
    "manifest": "./manifest.json"
  }
}
