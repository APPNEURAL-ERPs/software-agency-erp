{
  "id": "experienceos",
  "name": "ExperienceOS",
  "package": "@appneurox/experienceos",
  "version": "1.0.0",
  "description": "User experience, customer experience, journeys, onboarding, personalization, A/B testing, and experience optimization",
  "modes": [
    "standalone",
    "platform"
  ],
  "status": "active",
  "ownership": {
    "owner": "APPNEURAL",
    "domainOwner": "ExperienceOS Team",
    "visibility": "private",
    "reviewDate": "TBD"
  },
  "api": {
    "basePath": "/v1/experience",
    "standalonePath": "/experienceos",
    "docsPath": "/docs"
  },
  "entrypoints": {
    "api": "./dist/main.js",
    "manifest": "./manifest.json"
  },
  "commands": [
    "experience.persona.create",
    "experience.journey.create",
    "experience.flow.create",
    "experience.audit.generate"
  ],
  "workflows": [
    "experience.default.workflow"
  ],
  "events": {
    "publishes": [
      "experience.persona.created",
      "experience.journey.created",
      "experience.flow.created",
      "experience.audit.completed"
    ],
    "subscribes": []
  },
  "permissions": [
    "experience.persona.read",
    "experience.persona.write",
    "experience.journey.read",
    "experience.journey.write",
    "experience.flow.read",
    "experience.flow.write",
    "experience.audit.read",
    "experience.audit.write",
    "experience.abtest.read",
    "experience.abtest.write",
    "experience.feedback.read",
    "experience.feedback.write"
  ],
  "dependencies": {
    "required": [
      "@appneurox/platformos",
      "@appneurox/securityos"
    ],
    "optional": [
      "@appneurox/aios"
    ]
  },
  "dataClassification": "internal",
  "relatedSystems": [
    "platformos",
    "securityos",
    "aios"
  ],
  "runtime": {
    "port": 9400,
    "localBaseUrl": "http://localhost:9400"
  }
}
