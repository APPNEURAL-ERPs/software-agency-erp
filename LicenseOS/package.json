{
  "name": "@appneurox/licenseos",
  "version": "1.0.0",
  "description": "LicenseOS: software licenses, entitlements, usage tracking, compliance, renewals, and license lifecycle.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "npm run build && node dist/main.js",
    "seed": "npm run build && node dist/seed.js",
    "reset": "rm -f data/licenseos.db.json && npm run seed",
    "test": "npm run build && node --test tests/*.test.cjs"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.7.5"
  },
  "keywords": [
    "appneurox",
    "licenseos",
    "licensing",
    "entitlements",
    "operating-system"
  ],
  "appneurox": {
    "os": "licenseos",
    "domain": "license",
    "modes": [
      "standalone",
      "platform"
    ],
    "manifest": "./manifest.json"
  }
}
