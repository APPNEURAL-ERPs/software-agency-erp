{
  "id": "deliveryos",
  "name": "DeliveryOS",
  "package": "@appneurox/deliveryos",
  "version": "1.0.0",
  "description": "Delivery, dispatch, shipment, logistics, fulfillment, handover, route, courier, proof-of-delivery, delivery tracking, and delivery performance management",
  "modes": [
    "standalone",
    "platform"
  ],
  "status": "active",
  "ownership": {
    "owner": "APPNEURAL",
    "domainOwner": "DeliveryOS Team",
    "visibility": "private",
    "reviewDate": "TBD"
  },
  "api": {
    "basePath": "/v1/delivery",
    "standalonePath": "/deliveryos",
    "docsPath": "/docs"
  },
  "entrypoints": {
    "api": "./dist/main.js",
    "manifest": "./manifest.json"
  },
  "commands": [
    "delivery.order.create",
    "delivery.dispatch",
    "delivery.track",
    "delivery.assign",
    "delivery.proof",
    "delivery.confirm"
  ],
  "workflows": [
    "delivery.order.workflow",
    "delivery.dispatch.workflow",
    "delivery.return.workflow"
  ],
  "events": {
    "publishes": [
      "delivery.created",
      "delivery.dispatched",
      "delivery.in_transit",
      "delivery.delivered",
      "delivery.failed",
      "delivery.returned",
      "delivery.confirmed"
    ],
    "subscribes": [
      "inventory.dispatched",
      "project.completed",
      "document.generated"
    ]
  },
  "permissions": [
    "delivery.order.read",
    "delivery.order.write",
    "delivery.shipment.read",
    "delivery.shipment.write",
    "delivery.driver.read",
    "delivery.driver.write",
    "delivery.route.read",
    "delivery.route.write",
    "delivery.tracking.read",
    "delivery.proof.read",
    "delivery.proof.write",
    "delivery.analytics.read",
    "delivery.audit.read"
  ],
  "dependencies": {
    "required": [
      "@appneurox/platformos",
      "@appneurox/securityos"
    ],
    "optional": [
      "@appneurox/inventoryos",
      "@appneurox/locationos",
      "@appneurox/notificationos"
    ]
  },
  "dataClassification": "internal",
  "relatedSystems": [
    "platformos",
    "securityos",
    "inventoryos",
    "locationos",
    "notificationos"
  ],
  "runtime": {
    "port": 11600,
    "localBaseUrl": "http://localhost:11600"
  }
}
