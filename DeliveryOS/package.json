{
  "name": "@appneurox/deliveryos",
  "version": "1.0.0",
  "description": "DeliveryOS: delivery, dispatch, shipment, logistics, fulfillment, handover, route, courier, proof-of-delivery, tracking, and delivery performance management.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "npm run build && node dist/main.js",
    "seed": "npm run build && node dist/scripts/seed.js",
    "reset": "rm -f data/deliveryos.db.json && npm run seed",
    "test": "npm run build && node --test tests/*.test.cjs"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "appneurox",
    "deliveryos",
    "delivery",
    "fulfillment",
    "tracking",
    "courier",
    "logistics"
  ],
  "appneurox": {
    "os": "deliveryos",
    "domain": "delivery",
    "modes": [
      "standalone",
      "platform"
    ],
    "manifest": "./manifest.json"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
