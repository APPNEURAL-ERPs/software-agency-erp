{
  "id": "peopleos",
  "name": "PeopleOS",
  "package": "@appneurox/peopleos",
  "version": "1.0.0",
  "description": "People operations engine: employees, hiring, onboarding, attendance, performance, engagement, and HR workflows",
  "modes": [
    "standalone",
    "platform"
  ],
  "status": "active",
  "ownership": {
    "owner": "APPNEURAL",
    "domainOwner": "PeopleOS Team",
    "visibility": "private",
    "reviewDate": "TBD"
  },
  "api": {
    "basePath": "/v1/people",
    "standalonePath": "/people",
    "docsPath": "/docs"
  },
  "entrypoints": {
    "api": "./dist/main.js",
    "manifest": "./manifest.json"
  },
  "commands": [
    "people.employee.create",
    "people.team.create",
    "people.role.create",
    "people.pipeline.create",
    "people.review.create",
    "people.engagement.create"
  ],
  "workflows": [
    "people.default.workflow"
  ],
  "agents": [
    "people.assistant"
  ],
  "events": {
    "publishes": [
      "people.employee.created",
      "people.employee.updated",
      "people.team.created",
      "people.pipeline.updated",
      "people.review.completed",
      "people.engagement.created"
    ],
    "subscribes": []
  },
  "permissions": [
    "people.employee.read",
    "people.employee.write",
    "people.team.read",
    "people.team.write",
    "people.role.read",
    "people.role.write",
    "people.pipeline.read",
    "people.pipeline.write",
    "people.review.read",
    "people.review.write",
    "people.engagement.read",
    "people.engagement.write",
    "people.audit.read"
  ],
  "dependencies": {
    "required": [
      "@appneurox/platformos"
    ],
    "optional": [
      "@appneurox/securityos",
      "@appneurox/financeos",
      "@appneurox/learningos"
    ]
  },
  "dataClassification": "internal",
  "aiAgentSafetyLevel": "approval-required-for-write-actions",
  "relatedSystems": [
    "platformos",
    "financeos",
    "learningos",
    "securityos"
  ],
  "runtime": {
    "port": 8400,
    "localBaseUrl": "http://localhost:8400"
  }
}
