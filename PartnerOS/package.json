{
  "name": "@appneurox/partneros",
  "version": "1.0.0",
  "description": "PartnerOS: partner programs, relationships, enablement, joint GTM, revenue sharing, and partner lifecycle",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "npm run build && node dist/main.js",
    "seed": "npm run build && node dist/scripts/seed.js",
    "reset": "rm -f data/partneros.db.json && npm run seed",
    "test": "npm run build && node --test tests/*.test.cjs"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.7.5"
  },
  "keywords": [
    "appneurox",
    "partneros",
    "operating-system",
    "partners",
    "ecosystem"
  ],
  "appneurox": {
    "os": "partneros",
    "domain": "partnerships",
    "modes": [
      "standalone",
      "platform"
    ],
    "manifest": "./manifest.json"
  }
}
