{
  "id": "partneros",
  "name": "PartnerOS",
  "package": "@appneurox/partneros",
  "version": "1.0.0",
  "description": "Partner programs, relationships, enablement, joint GTM, revenue sharing, and partner lifecycle",
  "modes": [
    "standalone",
    "platform"
  ],
  "status": "active",
  "ownership": {
    "owner": "APPNEURAL",
    "domainOwner": "PartnerOS Team",
    "visibility": "private",
    "reviewDate": "TBD"
  },
  "api": {
    "basePath": "/v1/partners",
    "standalonePath": "/partneros",
    "docsPath": "/docs"
  },
  "entrypoints": {
    "api": "./dist/main.js",
    "manifest": "./manifest.json"
  },
  "commands": [
    "partner.create",
    "partner.onboard",
    "partner.submit-lead",
    "partner.calculate-commission"
  ],
  "workflows": [
    "partner.onboarding.workflow",
    "partner.lead.approval.workflow",
    "partner.commission.workflow"
  ],
  "agents": [
    "partner.assistant"
  ],
  "events": {
    "publishes": [
      "partner.created",
      "partner.updated",
      "partner.lead.submitted",
      "partner.lead.converted",
      "partner.commission.calculated"
    ],
    "subscribes": [
      "sales.lead.created",
      "finance.payout.processed"
    ]
  },
  "permissions": [
    "partner.read",
    "partner.write",
    "partner.program.read",
    "partner.program.write",
    "partner.lead.read",
    "partner.lead.write",
    "partner.commission.read",
    "partner.commission.write",
    "partner.campaign.read",
    "partner.campaign.write",
    "partner.audit.read"
  ],
  "dependencies": {
    "required": [
      "@appneurox/platformos",
      "@appneurox/securityos"
    ],
    "optional": [
      "@appneurox/salesos",
      "@appneurox/financeos",
      "@appneurox/legalos",
      "@appneurox/growthos"
    ]
  },
  "dataClassification": "internal",
  "aiAgentSafetyLevel": "approval-required-for-write-actions",
  "relatedSystems": [
    "platformos",
    "securityos",
    "salesos",
    "financeos",
    "legalos",
    "growthos"
  ],
  "runtime": {
    "port": 10000,
    "localBaseUrl": "http://localhost:10000"
  }
}
