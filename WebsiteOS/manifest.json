{
  "id": "websiteos",
  "name": "WebsiteOS",
  "package": "@appneurox/websiteos",
  "version": "1.0.0",
  "description": "Website building, page generation, SEO, AEO/GEO, CMS, landing pages, forms, analytics, and publishing",
  "modes": [
    "standalone",
    "platform"
  ],
  "status": "active",
  "ownership": {
    "owner": "APPNEURAL",
    "domainOwner": "WebsiteOS Team",
    "visibility": "private",
    "reviewDate": "TBD"
  },
  "api": {
    "basePath": "/v1/website",
    "standalonePath": "/websiteos",
    "docsPath": "/docs"
  },
  "entrypoints": {
    "api": "./dist/main.js",
    "manifest": "./manifest.json"
  },
  "commands": [
    "website.create",
    "website.page.create",
    "website.landing.create",
    "website.form.create",
    "website.publish",
    "website.seo.audit",
    "website.cro.audit"
  ],
  "workflows": [
    "website.default.workflow"
  ],
  "agents": [
    "website.assistant",
    "website.seo.assistant",
    "website.builder.assistant"
  ],
  "events": {
    "publishes": [
      "website.created",
      "website.page.created",
      "website.page.published",
      "website.form.submitted",
      "website.analytics.updated"
    ],
    "subscribes": []
  },
  "permissions": [
    "website.read",
    "website.write",
    "website.page.read",
    "website.page.write",
    "website.form.read",
    "website.form.write",
    "website.analytics.read",
    "website.seo.manage",
    "website.publish"
  ],
  "dependencies": {
    "required": [
      "@appneurox/platformos",
      "@appneurox/securityos"
    ],
    "optional": [
      "@appneurox/aios",
      "@appneurox/analyticsos",
      "@appneurox/automationos"
    ]
  },
  "dataClassification": "internal",
  "aiAgentSafetyLevel": "approval-required-for-write-actions",
  "relatedSystems": [
    "platformos",
    "securityos",
    "aios",
    "analyticsos",
    "automationos"
  ],
  "runtime": {
    "port": 9300,
    "localBaseUrl": "http://localhost:9300"
  }
}
