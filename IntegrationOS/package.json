{
  "name": "@appneurox/integrationos",
  "version": "1.0.0",
  "description": "IntegrationOS: External integrations, connectors, sync rules, webhooks, OAuth, and integration marketplace",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "npm run build && node dist/main.js",
    "seed": "npm run build && node dist/scripts/seed.js",
    "reset": "rm -f data/integrationos.db.json && npm run seed",
    "test": "npm run build && node --test tests/*.test.cjs"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.7.5"
  },
  "keywords": [
    "appneurox",
    "integrationos",
    "operating-system",
    "integrations",
    "connectors",
    "webhooks",
    "sdk"
  ],
  "appneurox": {
    "os": "integrationos",
    "domain": "integrations",
    "modes": [
      "standalone",
      "platform"
    ],
    "manifest": "./manifest.json"
  }
}
