{
  "name": "@appneurox/taskos",
  "version": "1.0.0",
  "description": "TaskOS: Tasks, assignments, checklists, action items, ownership, priorities, deadlines, dependencies, approvals, execution tracking, and productivity coordination.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "npm run build && node dist/main.js",
    "seed": "npm run build && node dist/scripts/seed.js",
    "reset": "rm -f data/taskos.db.json && npm run seed",
    "test": "npm run build"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "appneurox",
    "taskos",
    "operating-system",
    "sdk"
  ],
  "appneurox": {
    "os": "taskos",
    "domain": "task",
    "modes": [
      "standalone",
      "platform"
    ],
    "manifest": "./manifest.json"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
