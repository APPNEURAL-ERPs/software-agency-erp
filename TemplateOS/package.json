{
  "name": "@appneurox/templateos",
  "version": "1.0.0",
  "description": "TemplateOS: reusable blueprint engine for documents, websites, workflows, prompts, agents, APIs, data models, dashboards, forms, certificates, policies, and micro-ERP starter kits",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "npm run build && node dist/main.js",
    "seed": "npm run build && node dist/scripts/seed.js",
    "reset": "rm -f data/templateos.db.json && npm run seed"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.7.5"
  },
  "keywords": [
    "appneurox",
    "templateos",
    "templates",
    "blueprints",
    "operating-system",
    "starter-kits"
  ],
  "appneurox": {
    "os": "templateos",
    "domain": "template",
    "modes": [
      "standalone",
      "platform"
    ],
    "manifest": "./manifest.json"
  }
}
