{
  "id": "templateos",
  "name": "TemplateOS",
  "package": "@appneurox/templateos",
  "version": "1.0.0",
  "description": "Reusable blueprints, templates, patterns, starter kits for apps, documents, workflows, prompts, agents, websites, emails, and business processes",
  "modes": [
    "standalone",
    "platform"
  ],
  "status": "active",
  "ownership": {
    "owner": "APPNEURAL",
    "domainOwner": "TemplateOS Team",
    "visibility": "private",
    "reviewDate": "TBD"
  },
  "api": {
    "basePath": "/v1/templates",
    "standalonePath": "/templateos",
    "docsPath": "/docs"
  },
  "entrypoints": {
    "api": "./dist/main.js",
    "manifest": "./manifest.json"
  },
  "commands": [
    "template.create",
    "template.render",
    "template.validate"
  ],
  "workflows": [
    "template.default.workflow"
  ],
  "events": {
    "publishes": [
      "template.created",
      "template.updated",
      "template.rendered",
      "template.published"
    ],
    "subscribes": []
  },
  "permissions": [
    "template.read",
    "template.write",
    "template.render",
    "template.validate",
    "template.audit.read"
  ],
  "dependencies": {
    "required": [
      "@appneurox/platformos",
      "@appneurox/securityos"
    ],
    "optional": []
  },
  "dataClassification": "internal",
  "relatedSystems": [
    "platformos",
    "securityos",
    "documentos",
    "websiteos",
    "workflowos",
    "notificationos",
    "aios",
    "marketplaceos"
  ],
  "runtime": {
    "port": 6800,
    "localBaseUrl": "http://localhost:6800"
  }
}
